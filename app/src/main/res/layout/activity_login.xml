<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="30dp"
    android:background="#100f0f"
    android:gravity="center"
    android:layoutDirection="rtl"> <ImageView
    android:layout_width="150dp"
    android:layout_height="150dp"
    android:src="@drawable/app_logo"
    android:layout_marginBottom="30dp"/>

    <EditText
        android:id="@+id/et_email"
        android:layout_width="match_parent"
        android:layout_height="55dp"
        android:hint="البريد الإلكتروني"
        android:paddingRight="20dp"
        android:paddingLeft="20dp"
        android:background="@drawable/custom_input"
        android:textColor="@color/white"
        android:textColorHint="@color/gray_hint"
        android:layout_marginBottom="15dp"
        android:gravity="right|center_vertical"/> <EditText
        android:id="@+id/et_password"
        android:layout_width="match_parent"
        android:layout_height="55dp"
        android:hint="كلمة المرور"
        android:paddingRight="20dp"
        android:paddingLeft="20dp"
        android:background="@drawable/custom_input"
        android:textColor="@color/white"
        android:textColorHint="@color/gray_hint"
        android:inputType="textPassword"
        android:layout_marginBottom="25dp"
        android:gravity="right|center_vertical"/> <Button
        android:id="@+id/btn_login"
        android:layout_width="match_parent"
        android:layout_height="55dp"
        android:text="تسجيل الدخول"
        android:backgroundTint="@color/logo_red"
        android:textColor="@color/white"
        android:textSize="18sp"
        android:textStyle="bold"
        app:cornerRadius="15dp" />

    <TextView
        android:id="@+id/tv_register"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="ليس لديك حساب؟ سجل الآن"
        android:textColor="@color/purple_500"
        android:layout_marginTop="20dp"
        android:textSize="14sp"/>
</LinearLayout>