<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="8dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="4dp"
    android:layoutDirection="rtl">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="15dp">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <TextView
                android:id="@+id/tv_res_car_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="اسم السيارة"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#2196F3"
                android:layout_alignParentStart="true"
                android:layout_centerVertical="true"/>

            <ImageView
                android:id="@+id/btn_delete_booking"
                android:layout_width="35dp"
                android:layout_height="35dp"
                android:layout_alignParentEnd="true"
                android:padding="8dp"
                android:src="@android:drawable/ic_menu_delete"
                app:tint="#E91E63"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:clickable="true"
                android:focusable="true" />
        </RelativeLayout>

        <TextView
            android:id="@+id/tv_res_dates"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="من 01/01 إلى 05/01"
            android:layout_marginTop="5dp"
            android:textColor="#555"/>

        <TextView
            android:id="@+id/tv_res_total_price"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="السعر الإجمالي: 1000 شيكل"
            android:textColor="#E91E63"
            android:textStyle="bold"
            android:layout_marginTop="5dp"/>

        <TextView
            android:id="@+id/tv_res_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="نشط"
            android:layout_marginTop="10dp"
            android:paddingHorizontal="12dp"
            android:paddingVertical="4dp"
            android:textColor="#FFFFFF"
            android:textSize="12sp"
            android:textStyle="bold"
            android:background="@android:color/holo_green_dark" />
    </LinearLayout>
</androidx.cardview.widget.CardView>